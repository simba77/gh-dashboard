# EditorConfig: https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
max_line_length = 100

# Rust
[*.rs]
indent_size = 4
max_line_length = 100

# Markdown — не обрезаем пробелы (двойной пробел = перенос строки)
[*.md]
trim_trailing_whitespace = false

# Makefile требует табы, не пробелы
[Makefile]
indent_style = tab

# Lockfiles не редактируем вручную — не навязываем правила
[{package-lock.json,Cargo.lock}]
indent_size = unset
